# Project Makefile
# Standard interface: sync, fmt, lint, typecheck, test, check, qa, clean, help
SHELL := /bin/bash
.SILENT:
.ONESHELL:
.DEFAULT_GOAL := help

#------------------------------------------------------------------------------
# Configuration
#------------------------------------------------------------------------------

# Add tool commands and project variables here
# Example: TOOL := tool-name
# Example: SRC_DIR := src

#------------------------------------------------------------------------------
# Phony Targets Declaration
#------------------------------------------------------------------------------

.PHONY: help sync fmt lint typecheck check qa clean distclean
.PHONY: test test.unit test.integration test.e2e test.watch
.PHONY: doc doc.build doc.serve build

#------------------------------------------------------------------------------
# High-Level Targets
#------------------------------------------------------------------------------

check: fmt lint typecheck
qa: check test
test: test.unit

#------------------------------------------------------------------------------
# Installation & Dependencies
#------------------------------------------------------------------------------

sync:
	echo "Install dependencies here"

#------------------------------------------------------------------------------
# Code Quality
#------------------------------------------------------------------------------

fmt:
	echo "Format code here"

lint:
	echo "Lint code with auto-fix here"

typecheck:
	echo "Type check here"

#------------------------------------------------------------------------------
# Testing
#------------------------------------------------------------------------------

test.unit:
	echo "Run unit tests here"

test.integration:
	echo "Run integration tests here"

test.e2e:
	echo "Run e2e tests here"

test.watch:
	echo "Run tests in watch mode here"

#------------------------------------------------------------------------------
# Documentation
#------------------------------------------------------------------------------

doc.build:
	echo "Build documentation here"

doc.serve:
	echo "Serve documentation here"

doc: doc.build

#------------------------------------------------------------------------------
# Build
#------------------------------------------------------------------------------

build:
	echo "Build project here"

#------------------------------------------------------------------------------
# Cleanup
#------------------------------------------------------------------------------

clean:
	echo "Clean build artifacts here"

distclean: clean
	echo "Deep clean here"

#------------------------------------------------------------------------------
# Help
#------------------------------------------------------------------------------

help:
	# Banner generated by: make_banner {"text": "MAKE"}
	# Replace "MAKE" with your project name before using this template.
	printf "\033[36m"
	printf "╔╦╗╔═╗╦╔ ╔═╗\n"
	printf "║║║╠═╣╠╩╗║╣ \n"
	printf "╝ ╝╝ ╝╝ ╝╚═╝\n"
	printf "\033[0m\n"
	printf "Usage: make [target]\n\n"
	printf "\033[1;35mSetup:\033[0m\n"
	printf "  sync            - Install dependencies\n"
	printf "\n"
	printf "\033[1;35mDevelopment:\033[0m\n"
	printf "  fmt             - Format code\n"
	printf "  lint            - Lint and auto-fix\n"
	printf "  typecheck       - Validate types\n"
	printf "  check           - fmt + lint + typecheck\n"
	printf "  qa              - check + test (quality gate)\n"
	printf "\n"
	printf "\033[1;35mTesting:\033[0m\n"
	printf "  test            - Run all tests\n"
	printf "  test.unit       - Unit tests only\n"
	printf "  test.integration - Integration tests\n"
	printf "  test.e2e        - End-to-end tests\n"
	printf "  test.watch      - Tests in watch mode\n"
	printf "\n"
	printf "\033[1;35mDocumentation:\033[0m\n"
	printf "  doc.build       - Build documentation\n"
	printf "  doc.serve       - Serve documentation locally\n"
	printf "\n"
	printf "\033[1;35mBuild:\033[0m\n"
	printf "  build           - Build project\n"
	printf "\n"
	printf "\033[1;35mCleanup:\033[0m\n"
	printf "  clean           - Remove build artifacts\n"
	printf "  distclean       - Deep clean (includes dist/)\n"
